<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhbookstore.system.mapper.member.PointsUserIntoBillDetailMapper">

    <resultMap type="com.xhbookstore.system.domain.member.PointsUserIntoBillDetail" id="PointsUserIntoBillDetailResult">
        <id property="id" column="id"/>
        <result property="memberId" column="member_id"/>
        <result property="points" column="points"/>
        <result property="remainingPoints" column="remaining_points"/>
        <result property="description" column="description"/>
        <result property="orderNoSrc" column="order_no_src"/>
        <result property="orderNoTarget" column="order_no_target"/>
        <result property="activityKey" column="activity_key"/>
        <result property="activityName" column="activity_name"/>
        <result property="eventKey" column="event_key"/>
        <result property="eventName" column="event_name"/>
        <result property="accountType" column="account_type"/>
        <result property="billStatus" column="bill_status"/>
        <result property="isWhiteOrder" column="is_white_order"/>
        <result property="expiredTime" column="expired_time"/>
        <result property="expiredTimestamp" column="expired_timestamp"/>
        <result property="isDel" column="is_del"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insertIntoBill" parameterType="com.xhbookstore.system.domain.member.PointsUserIntoBillDetail" useGeneratedKeys="true" keyProperty="id">
        insert into xhbs_points_user_into_bill_detail (
            member_id, points, remaining_points, description,
            order_no_src, order_no_target, activity_key, activity_name,
            event_key, event_name, account_type, bill_status,
            is_white_order, expired_time, expired_timestamp,
            is_del, created_at, updated_at
        ) values (
            #{memberId}, #{points}, #{points}, #{description},
            #{orderNoSrc}, #{orderNoTarget}, #{activityKey}, #{activityName},
            #{eventKey}, #{eventName}, #{accountType}, #{billStatus},
            #{isWhiteOrder}, #{expiredTime}, #{expiredTimestamp},
            #{isDel}, now(), now()
        )
    </insert>

</mapper>
