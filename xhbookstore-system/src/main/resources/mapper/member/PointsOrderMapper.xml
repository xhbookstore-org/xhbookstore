<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhbookstore.system.mapper.member.PointsOrderMapper">

    <resultMap type="com.xhbookstore.system.domain.member.PointsOrder" id="PointsOrderResult">
        <id property="id" column="id"/>
        <result property="orderNumber" column="order_number"/>
        <result property="openId" column="open_id"/>
        <result property="cardNo" column="card_no"/>
        <result property="memberId" column="member_id"/>
        <result property="appOrderNumber" column="app_order_number"/>
        <result property="amount" column="amount"/>
        <result property="description" column="description"/>
        <result property="type" column="type"/>
        <result property="customArgs" column="custom_args"/>
        <result property="completedTime" column="completed_time"/>
        <result property="orderTime" column="order_time"/>
        <result property="clientIp" column="client_ip"/>
        <result property="itemId" column="item_id"/>
        <result property="itemName" column="item_name"/>
        <result property="price" column="price"/>
        <result property="discountedPrice" column="discounted_price"/>
        <result property="operationDevice" column="operation_device"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="isDel" column="is_del"/>
        <result property="amountType" column="amount_type"/>
        <result property="appId" column="app_id"/>
        <result property="orginPoints" column="orgin_points"/>
        <result property="afterPoints" column="after_points"/>
    </resultMap>

    <insert id="insertPointsOrder" parameterType="com.xhbookstore.system.domain.member.PointsOrder" useGeneratedKeys="true" keyProperty="id">
        insert into xhbs_points_order (
            order_number, open_id, card_no, member_id, app_order_number,
            amount, description, type, custom_args, completed_time,
            order_time, client_ip, item_id, item_name, price,
            discounted_price, operation_device, created_at, updated_at,
            is_del, amount_type, app_id, orgin_points, after_points
        ) values (
            #{orderNumber}, #{openId}, #{cardNo}, #{memberId}, #{appOrderNumber},
            #{amount}, #{description}, #{type}, #{customArgs}, now(),
            now(), #{clientIp}, #{itemId}, #{itemName}, #{price},
            #{discountedPrice}, #{operationDevice}, now(), now(),
            #{isDel}, #{amountType}, #{appId}, #{orginPoints}, #{afterPoints}
        )
    </insert>

    <select id="selectByOrderNumber" parameterType="String" resultMap="PointsOrderResult">
        select * from xhbs_points_order where order_number = #{orderNumber}
    </select>

    <select id="selectByMemberId" parameterType="Integer" resultMap="PointsOrderResult">
        select * from xhbs_points_order where member_id = #{memberId} and is_del = 0
        order by created_at desc
    </select>

</mapper>
