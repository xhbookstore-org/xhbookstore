<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhbookstore.system.mapper.member.CardTypeMapper">

    <resultMap type="com.xhbookstore.system.domain.member.CardType" id="CardTypeResult">
        <id property="id" column="id"/>
        <result property="typeName" column="type_name"/>
        <result property="price" column="price"/>
        <result property="validDays" column="valid_days"/>
        <result property="borrowLimit" column="borrow_limit"/>
        <result property="discount" column="discount"/>
        <result property="isRenewal" column="is_renewal"/>
        <result property="description" column="description"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="isDel" column="is_del"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="selectAll" resultMap="CardTypeResult">
        select * from util_card_type where is_del = 0 order by sort asc, id asc
    </select>

    <select id="selectById" parameterType="Integer" resultMap="CardTypeResult">
        select * from util_card_type where id = #{id}
    </select>

    <insert id="insert" parameterType="com.xhbookstore.system.domain.member.CardType" useGeneratedKeys="true" keyProperty="id">
        insert into util_card_type (type_name, price, valid_days, borrow_limit, discount, is_renewal, description, sort, status, create_by, create_time)
        values (#{typeName}, #{price}, #{validDays}, #{borrowLimit}, #{discount}, #{isRenewal}, #{description}, #{sort}, #{status}, #{createBy}, now())
    </insert>

    <update id="update" parameterType="com.xhbookstore.system.domain.member.CardType">
        update util_card_type
        <set>
            <if test="typeName != null">type_name = #{typeName},</if>
            <if test="price != null">price = #{price},</if>
            <if test="validDays != null">valid_days = #{validDays},</if>
            <if test="borrowLimit != null">borrow_limit = #{borrowLimit},</if>
            <if test="discount != null">discount = #{discount},</if>
            <if test="isRenewal != null">is_renewal = #{isRenewal},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = now()
        </set>
        where id = #{id}
    </update>

    <update id="deleteById" parameterType="Integer">
        update util_card_type set is_del = 1, update_time = now() where id = #{id}
    </update>

</mapper>