<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhbookstore.system.mapper.member.CardTypeMapper">

    <resultMap type="com.xhbookstore.system.domain.member.CardType" id="CardTypeResult">
        <id property="id" column="id"/>
        <result property="typeName" column="type_name"/>
        <result property="validDays" column="valid_days"/>
        <result property="isRenewal" column="is_renewal"/>
        <result property="status" column="status"/>
        <result property="sort" column="sort"/>
    </resultMap>

    <select id="selectAll" resultMap="CardTypeResult">
        select * from card_type where status = 0 order by sort asc, id asc
    </select>

    <select id="selectById" parameterType="Integer" resultMap="CardTypeResult">
        select * from card_type where id = #{id}
    </select>

</mapper>