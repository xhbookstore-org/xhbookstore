<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhbookstore.system.mapper.book.BookInfoMapper">

    <resultMap type="com.xhbookstore.system.domain.book.BookInfo" id="BookInfoResult">
        <id property="id" column="id"/>
        <result property="bookName" column="book_name"/>
        <result property="isbn" column="isbn"/>
        <result property="author" column="author"/>
        <result property="publisher" column="publisher"/>
        <result property="price" column="price"/>
        <result property="salePrice" column="sale_price"/>
        <result property="stockQty" column="stock_qty"/>
        <result property="lendableQty" column="lendable_qty"/>
        <result property="bookStatus" column="book_status"/>
        <result property="coverUrl" column="cover_url"/>
        <result property="description" column="description"/>
        <result property="remark" column="remark"/>
        <result property="createStaffId" column="create_staff_id"/>
        <result property="createStaffName" column="create_staff_name"/>
        <result property="updateStaffId" column="update_staff_id"/>
        <result property="updateStaffName" column="update_staff_name"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="isDel" column="is_del"/>
    </resultMap>

    <select id="selectById" parameterType="Long" resultMap="BookInfoResult">
        select * from book_info where id = #{id} and is_del = 0
    </select>

    <select id="selectByIdForUpdate" parameterType="Long" resultMap="BookInfoResult">
        select * from book_info where id = #{id} and is_del = 0 for update
    </select>

    <update id="decreaseLendableQty">
        update book_info
        set lendable_qty = lendable_qty - #{qty}, updated_at = now()
        where id = #{id} and is_del = 0 and lendable_qty &gt;= #{qty}
    </update>

    <update id="increaseLendableQty">
        update book_info
        set lendable_qty = lendable_qty + #{qty}, updated_at = now()
        where id = #{id} and is_del = 0
    </update>
    <update id="decreaseStockQty">
        update book_info
        set stock_qty = stock_qty - #{qty}, updated_at = now()
        where id = #{id} and is_del = 0 and stock_qty &gt;= #{qty}
    </update>
</mapper>